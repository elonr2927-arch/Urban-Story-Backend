# ─────────────────────────────────────────────
#  NestQuest API — Environment Variables
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=8000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nestquest

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — Frontend origin (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3000

# Cookie
COOKIE_DOMAIN=localhost

# Email (Nodemailer — use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=no-reply@nestquest.com

# App URL (used in password reset emails)
APP_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
